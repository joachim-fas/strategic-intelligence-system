# ═══════════════════════════════════════════════════════════════════════════
# Strategic Intelligence System — Environment Variables
# ═══════════════════════════════════════════════════════════════════════════
#
# Copy this file to .env.local and fill in the values.
# For local development WITHOUT Supabase, leave DATABASE_URL empty —
# the app will fall back to a local SQLite database (local.db).
#
# Run `npm run db:setup` to initialise and seed the local SQLite database.
# ═══════════════════════════════════════════════════════════════════════════

# ─── Database ──────────────────────────────────────────────────────────────
# PostgreSQL (Supabase). Leave empty for local SQLite fallback.
DATABASE_URL=

# ─── Authentication (NextAuth v5) ─────────────────────────────────────────
# Secret key for signing tokens. Generate with: openssl rand -base64 32
AUTH_SECRET=your-secret-here-generate-with-openssl

# NextAuth URL (set automatically on Vercel; needed for local dev)
NEXTAUTH_URL=http://localhost:3000

# Comma-separated email allowlist. Only these emails can sign in.
# Leave empty to allow all emails (useful for local development).
ALLOWED_EMAILS=admin@example.com,team@example.com

# ─── Email Provider (for magic link sign-in) ──────────────────────────────
# Resend (recommended — free tier: 100 emails/day)
RESEND_API_KEY=re_...

# Or use a custom SMTP server:
# EMAIL_SERVER_HOST=smtp.resend.com
# EMAIL_SERVER_PORT=465
# EMAIL_SERVER_USER=resend
# EMAIL_SERVER_PASSWORD=re_...

# From address for sign-in emails
EMAIL_FROM=noreply@trend-radar.app

# ─── Pipeline / Cron ──────────────────────────────────────────────────────
# Secret for authenticating external cron calls (e.g., Vercel Cron).
# The cron endpoint expects: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=your-cron-secret-here

# ─── Claude API (for intelligent query processing) ────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Optional AI providers (Welle C Item 1) ───────────────────────────────
# OpenRouter fallback for src/lib/ai-text.ts — activates when set.
# Anthropic stays the primary provider; OpenRouter only fires on
# Anthropic 5xx / 429 / timeout. No behaviour change when unset.
# Sign up at: https://openrouter.ai/
# OPENROUTER_API_KEY=sk-or-...

# ─── Optional feature flags ───────────────────────────────────────────────
# Forecast-Layer: team prediction-market-lite with peer-signoff
# resolution + per-user Brier calibration. When unset, all
# /api/v1/forecasts/* routes return 404 and the /forecasts page
# renders a "feature not yet enabled" splash.
# FORECASTS_ENABLED=true

# Cluster-snapshot LLM enrichment. Both flags are independent; each
# adds ~30 LLM calls per pipeline run (every 4h in prod × ~30
# clusters). Opt in once the operator accepts the cost.
# CLUSTER_DIFF_LLM_ENABLED=true        # LLM changelog between snapshots
# CLUSTER_FORESIGHT_LLM_ENABLED=true   # LLM forward scenarios per snapshot

# Explicit opt-in to the dev-mode auth bypass. Keeps production
# builds safe even when NODE_ENV is misread. Only useful locally.
# SIS_ALLOW_DEV_AUTH=true

# ─── Data Source API Keys (optional — enhance signal quality) ─────────────
# All connector keys are optional. Missing keys = connector returns 0 signals.
#
# GitHub: Personal Access Token for higher rate limits (60 → 5000 req/h)
GITHUB_TOKEN=ghp_...

# The Guardian (open-platform.theguardian.com/access)
GUARDIAN_API_KEY=

# Finnhub — stock market, financial news (finnhub.io/register)
FINNHUB_API_KEY=

# FRED — Federal Reserve Economic Data (fred.stlouisfed.org/docs/api/api_key.html)
FRED_API_KEY=

# NewsAPI (newsapi.org) for news connector
NEWS_API_KEY=

# NewsData.io — global multi-language news (newsdata.io/register)
NEWSDATA_API_KEY=

# New York Times Article Search (developer.nytimes.com/get-started)
NYT_API_KEY=

# ACLED — Armed Conflict Location & Event Data (acleddata.com/register)
ACLED_EMAIL=
ACLED_KEY=

# Open Exchange Rates — currency data (openexchangerates.org/signup/free)
OPEN_EXCHANGE_KEY=

# Stack Overflow API key (stackapps.com/apps/oauth/register)
SO_API_KEY=

# Reddit API (for reddit connector — client credentials flow)
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=

# Google Trends (uses unofficial API, no key needed)
# GOOGLE_TRENDS_PROXY= (optional HTTP proxy)

# ─── Vercel-specific ──────────────────────────────────────────────────────
# These are set automatically by Vercel; only needed for manual deployment.
# VERCEL=1
# VERCEL_URL=your-project.vercel.app
