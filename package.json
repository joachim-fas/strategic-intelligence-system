{
  "name": "strategic-intelligence-system",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:init-local": "tsx src/db/migrate-sqlite.ts",
    "db:seed": "tsx src/db/seed.ts",
    "db:setup": "npm run db:init-local && npm run db:seed",
    "signals:pump": "tsx scripts/signals-pump.ts",
    "signals:status": "sqlite3 local.db \"SELECT source, COUNT(*) as n, ROUND((julianday('now') - julianday(MAX(fetched_at))) * 24, 1) as hours_ago FROM live_signals GROUP BY source ORDER BY hours_ago ASC LIMIT 40;\"",
    "tenant:bootstrap": "tsx scripts/tenant-bootstrap.ts",
    "test:tenants": "tsx scripts/tenant-smoke-test.ts",
    "test:api": "tsx scripts/api-smoke-test.ts",
    "test:stream": "tsx scripts/stream-query-retry-test.ts",
    "test": "npm run test:tenants && npm run test:stream && npm run test:api"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.7.0",
    "@radix-ui/react-slot": "^1.2.4",
    "@tanstack/react-virtual": "^3.13.23",
    "better-sqlite3": "^12.8.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3": "^7.9.0",
    "drizzle-orm": "^0.39.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.475.0",
    "next": "^15.2.0",
    "next-auth": "^5.0.0-beta.25",
    "postgres": "^3.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/d3": "^7.4.3",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.30.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.2.0",
    "postcss": "^8.5.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0"
  }
}
